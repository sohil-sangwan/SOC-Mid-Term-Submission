#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;
    
    vector<int> a(n);
    int ones = 0;
    for (int i = 0; i < n; i++) {
        cin >> a[i];
        ones += a[i];
    }
    
    // Transform: 0 -> +1, 1 -> -1
    vector<int> t(n);
    for (int i = 0; i < n; i++)
        t[i] = 1 - 2 * a[i];
    
    // Kadane's algorithm (must flip at least one element)
    int max_gain = t[0], current = t[0];
    for (int i = 1; i < n; i++) {
        current = max(t[i], current + t[i]);
        max_gain = max(max_gain, current);
    }
    
    cout << ones + max_gain << endl;
    return 0;
}
