#include <bits/stdc++.h>
using namespace std;

int main(){
    int n, t;
    cin >> n >> t;
    string s;
    cin >> s;
    for(int i=0; i<t; i++){
        for(int j=0; j<n; j++){
            char a = s[j];
            if(s[j] == 'B' && s[j+1] == 'G'){
                s[j] = s[j+1];
                s[j+1] = a;
                j++;
            }
        }
    }
    cout << s << endl;
}
