#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n;
    cin >> n;
    vector<int> p(n);
    for (int i = 0; i < n; i++) {
        cin >> p[i];
    }

    int odd_subarrays_count = 0;
    int i = 0;
    
    // Greedily look for adjacent inversions
    while (i < n - 1) {
        if (p[i] > p[i + 1]) {
            odd_subarrays_count++;
            i += 2; // Consume both elements and jump forward
        } else {
            i += 1; // Move to the next element
        }
    }

    cout << odd_subarrays_count << "\n";
}

int main() {
    // Optimize standard I/O operations for competitive programming speed
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    return 0;
}
