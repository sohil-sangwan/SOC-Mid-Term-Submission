#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n;
    cin >> n;
    string s;
    cin >> s;

    int coins = 0;
    
    // Scan through the path starting from index 0
    for (int i = 0; i < n; i++) {
        // If we hit two thorns in a row, we are blocked completely
        if (i > 0 && s[i] == '*' && s[i - 1] == '*') {
            break;
        }
        
        // If it's a coin, collect it
        if (s[i] == '@') {
            coins++;
        }
    }

    cout << coins << "\n";
}

int main() {
    // Fast I/O for competitive programming
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    return 0;
}
