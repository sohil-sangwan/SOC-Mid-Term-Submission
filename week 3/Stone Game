#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n;
    cin >> n;
    vector<int> a(n);
    
    int min_idx = 0, max_idx = 0;
    
    for (int i = 0; i < n; i++) {
        cin >> a[i];
        // Track the index of the minimum element
        if (a[i] < a[min_idx]) {
            min_idx = i;
        }
        // Track the index of the maximum element
        if (a[i] > a[max_idx]) {
            max_idx = i;
        }
    }
    
    // Ensure pos1 is always the smaller index, and pos2 is the larger index
    int pos1 = min(min_idx, max_idx);
    int pos2 = max(min_idx, max_idx);
    
    // Calculate the 3 possible choices
    int op1 = pos2 + 1;                  // Both from left
    int op2 = n - pos1;                  // Both from right
    int op3 = (pos1 + 1) + (n - pos2);   // One from left, one from right
    
    // Output the minimum of the three options
    cout << min({op1, op2, op3}) << "\n";
}

int main() {
    // Fast I/O
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    return 0;
}
