#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n;
    cin >> n;
    vector<int> a(n);
    
    int max_even = 0; // Tracks max value at indices 0, 2, 4...
    int max_odd = 0;  // Tracks max value at indices 1, 3, 5...
    
    for (int i = 0; i < n; i++) {
        cin >> a[i];
        if (i % 2 == 0) {
            max_even = max(max_even, a[i]);
        } else {
            max_odd = max(max_odd, a[i]);
        }
    }
    
    // Formula for count of elements:
    int count_even = (n + 1) / 2;
    int count_odd = n / 2;
    
    // Calculate total potential score for both paths
    int score_even = max_even + count_even;
    int score_odd = max_odd + count_odd;
    
    // Output the higher score
    cout << max(score_even, score_odd) << "\n";
}

int main() {
    // Fast I/O for competitive programming
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    return 0;
}

