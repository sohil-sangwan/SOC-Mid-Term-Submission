#include <iostream>
#include <vector>

using namespace std;

void solve() {
    int n;
    cin >> n;
    vector<long long> a(n);
    for (int i = 0; i < n; ++i) {
        cin >> a[i];
    }

    // If n is odd, it's always possible
    if (n % 2 == 1) {
        cout << "YES\n";
        return;
    }

    // If n is even, perform a greedy left-to-right pass
    for (int i = 1; i < n - 1; i += 2) {
        // We eliminate differences in pairs of steps or element by element
        // A simpler way is to just do a continuous ripple pass:
    }
    
    // Alternative clean implementation of the ripple pass:
    for (int i = 1; i < n - 1; ++i) {
        long long diff = a[i - 1] - a[i];
        a[i] += diff;
        a[i + 1] += diff;
    }

    // Check if the last pair satisfies the non-decreasing condition
    if (a[n - 2] <= a[n - 1]) {
        cout << "YES\n";
    } else {
        cout << "NO\n";
    }
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    
    return 0;
}
