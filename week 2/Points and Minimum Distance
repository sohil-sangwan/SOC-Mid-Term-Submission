#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

void solve() {
    int n;
    cin >> n;
    vector<int> a(2 * n);
    for (int i = 0; i < 2 * n; ++i) {
        cin >> a[i];
    }

    // Step 1: Sort the array
    sort(a.begin(), a.end());

    // Step 2: Calculate the minimum path distance
    // x_n is at index n-1, x_1 is at index 0
    // y_n is at index 2n-1, y_1 is at index n
    int min_distance = (a[n - 1] - a[0]) + (a[2 * n - 1] - a[n]);
    cout << min_distance << "\n";

    // Step 3: Print the paired points
    for (int i = 0; i < n; ++i) {
        cout << a[i] << " " << a[i + n] << "\n";
    }
}

int main() {
    // Optimize standard I/O operations for performance
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        solve();
    }

    return 0;
}
